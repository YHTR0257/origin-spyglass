# Docker / backend
BACKEND_PORT=8000
FRONTEND_PORT=8080

# App settings
APP_NAME=llm-agent-boilerplate
ENVIRONMENT=docker

# PostgreSQL
POSTGRES_VERSION=16
POSTGRES_CONTAINER_NAME=origin-spyglass-postgres
POSTGRES_PORT=5432
POSTGRES_DB=spyglass
POSTGRES_USER=spyglass
POSTGRES_PASSWORD=spyglass
DATABASE_URL=postgresql+asyncpg://spyglass:spyglass@origin-spyglass-postgres:5432/spyglass
